{"title":"Test coverage snapshot (sortable)","gitnotes":1,"type":"html","body":"<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<style>\n  :root { --bg:#111; --fg:#eaeaea; --muted:#888; --head:#1c1c1c; }\n  body { font:14px/1.4 system-ui,sans-serif; background:var(--bg); color:var(--fg); margin:0; padding:1.5rem 2rem; }\n  h1 { font-size:1.2rem; margin:0 0 1rem; }\n  table { border-collapse:collapse; width:100%; max-width:40rem; }\n  th { background:var(--head); cursor:pointer; user-select:none; padding:.5rem .65rem; text-align:left; border-bottom:2px solid #333; }\n  th:hover { color:#fff; }\n  td { padding:.45rem .65rem; border-bottom:1px solid #222; }\n  tr.pass td:last-child { color:#3fb950; }\n  tr.gap td:last-child { color:#d29922; }\n</style>\n</head>\n<body>\n<h1>Test matrix — click headers to sort</h1>\n<table id=\"t\">\n  <thead><tr>\n    <th data-col=\"0\">Suite</th>\n    <th data-col=\"1\">Case</th>\n    <th data-col=\"2\">Status</th>\n  </tr></thead>\n  <tbody>\n    <tr class=\"pass\"><td>LRUCache</td><td>evicts LRU entry</td><td>PASS</td></tr>\n    <tr class=\"pass\"><td>LRUCache</td><td>hit/miss stats</td><td>PASS</td></tr>\n    <tr class=\"pass\"><td>RequestCoalescer</td><td>concurrent dedup</td><td>PASS</td></tr>\n    <tr class=\"gap\"><td>TTLCache</td><td>lazy expiry</td><td>TODO</td></tr>\n    <tr class=\"gap\"><td>TTLCache</td><td>prune sweep</td><td>TODO</td></tr>\n  </tbody>\n</table>\n<script>\n(function() {\n  var table = document.getElementById('t');\n  var tbody = table.querySelector('tbody');\n  var sortCol = -1, asc = true;\n  table.querySelectorAll('th').forEach(function(th) {\n    th.addEventListener('click', function() {\n      var col = parseInt(th.dataset.col, 10);\n      if (sortCol === col) asc = !asc; else { sortCol = col; asc = true; }\n      var rows = Array.from(tbody.querySelectorAll('tr'));\n      rows.sort(function(a, b) {\n        var av = a.children[col].textContent, bv = b.children[col].textContent;\n        return asc ? av.localeCompare(bv) : bv.localeCompare(av);\n      });\n      rows.forEach(function(r) { tbody.appendChild(r); });\n    });\n  });\n})();\n</script>\n</body>\n</html>"}
