{"title":"Benchmark: eviction path before/after","gitnotes":1,"type":"html","body":"<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<style>\n  :root { --bg:#0b0f14; --fg:#e8eef4; --muted:#6e7a86; --grid:#1e2833; }\n  body { font:14px/1.45 system-ui,sans-serif; background:var(--bg); color:var(--fg); margin:0; padding:1.5rem 2rem; }\n  h1 { font-size:1.25rem; margin:0 0 .25rem; }\n  .meta { color:var(--muted); margin:0 0 1.25rem; font-size:.88rem; }\n  svg { max-width:100%; height:auto; }\n  .legend { display:flex; gap:1.25rem; margin-top:.75rem; font-size:.85rem; }\n  .swatch { display:inline-block; width:.75rem; height:.75rem; border-radius:2px; vertical-align:middle; margin-right:.35rem; }\n</style>\n</head>\n<body>\n<h1>LRU hot-path microbenchmark</h1>\n<p class=\"meta\">1M mixed get/set ops, maxSize=256, 80% updates to existing keys — Node 22, WSL2</p>\n<svg viewBox=\"0 0 420 200\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Bar chart\">\n  <rect width=\"420\" height=\"200\" fill=\"#0b0f14\"/>\n  <line x1=\"50\" y1=\"160\" x2=\"390\" y2=\"160\" stroke=\"#2a3544\" stroke-width=\"1\"/>\n  <line x1=\"50\" y1=\"30\" x2=\"50\" y2=\"160\" stroke=\"#2a3544\" stroke-width=\"1\"/>\n  <text x=\"48\" y=\"168\" fill=\"#6e7a86\" font-size=\"10\" text-anchor=\"end\">0</text>\n  <text x=\"48\" y=\"95\" fill=\"#6e7a86\" font-size=\"10\" text-anchor=\"end\">500ms</text>\n  <text x=\"48\" y=\"35\" fill=\"#6e7a86\" font-size=\"10\" text-anchor=\"end\">1000ms</text>\n  <rect x=\"90\" y=\"72\" width=\"80\" height=\"88\" fill=\"#484f58\" rx=\"3\"/>\n  <text x=\"130\" y=\"62\" fill=\"#e8eef4\" font-size=\"11\" text-anchor=\"middle\">892ms</text>\n  <text x=\"130\" y=\"178\" fill=\"#8b949e\" font-size=\"10\" text-anchor=\"middle\">before</text>\n  <rect x=\"230\" y=\"88\" width=\"80\" height=\"72\" fill=\"#238636\" rx=\"3\"/>\n  <text x=\"270\" y=\"78\" fill=\"#7ee787\" font-size=\"11\" text-anchor=\"middle\">731ms</text>\n  <text x=\"270\" y=\"178\" fill=\"#8b949e\" font-size=\"10\" text-anchor=\"middle\">after</text>\n  <text x=\"350\" y=\"100\" fill=\"#7ee787\" font-size=\"13\" font-weight=\"600\">−18%</text>\n  <text x=\"210\" y=\"18\" fill=\"#6e7a86\" font-size=\"11\" text-anchor=\"middle\">wall time (lower is better)</text>\n</svg>\n<div class=\"legend\">\n  <span><span class=\"swatch\" style=\"background:#484f58\"></span>pre-refactor (double lookup on set hit)</span>\n  <span><span class=\"swatch\" style=\"background:#238636\"></span>touch() helper + early return</span>\n</div>\n</body>\n</html>"}
