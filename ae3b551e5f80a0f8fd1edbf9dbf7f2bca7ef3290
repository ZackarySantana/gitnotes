{"title":"Latency histogram (interactive canvas)","gitnotes":1,"type":"html","body":"<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<style>\n  :root { --bg:#0a0e12; --fg:#dde3ea; --muted:#727e8c; }\n  body { font:14px/1.45 system-ui,sans-serif; background:var(--bg); color:var(--fg); margin:0; padding:1.5rem 2rem; }\n  h1 { font-size:1.2rem; margin:0 0 .35rem; }\n  p { color:var(--muted); margin:0 0 1rem; }\n  canvas { background:#11161d; border:1px solid #243040; border-radius:6px; display:block; max-width:100%; }\n  .stats { display:flex; gap:1.5rem; margin-top:.75rem; font-size:.9rem; }\n  .stats span { color:var(--muted); }\n  .stats strong { color:#7ee787; }\n</style>\n</head>\n<body>\n<h1>get() latency distribution</h1>\n<p>Synthetic sample from bench harness (500k ops, maxSize=256). Click canvas to resample.</p>\n<canvas id=\"c\" width=\"480\" height=\"220\"></canvas>\n<div class=\"stats\">\n  <div><span>p50</span> <strong id=\"p50\">—</strong></div>\n  <div><span>p95</span> <strong id=\"p95\">—</strong></div>\n  <div><span>p99</span> <strong id=\"p99\">—</strong></div>\n</div>\n<script>\n(function() {\n  var canvas = document.getElementById('c');\n  var ctx = canvas.getContext('2d');\n  function sample() {\n    var bins = 24, data = new Array(bins).fill(0);\n    var raw = [];\n    for (var i = 0; i < 800; i++) {\n      var u = Math.random();\n      var lat = u < 0.7 ? 0.02 + Math.random() * 0.08 : 0.12 + Math.random() * 0.35;\n      raw.push(lat);\n      var b = Math.min(bins - 1, Math.floor(lat * 100));\n      data[b]++;\n    }\n    raw.sort(function(a,b){ return a-b; });\n    document.getElementById('p50').textContent = (raw[Math.floor(raw.length*0.5)]*1000).toFixed(1) + 'µs';\n    document.getElementById('p95').textContent = (raw[Math.floor(raw.length*0.95)]*1000).toFixed(1) + 'µs';\n    document.getElementById('p99').textContent = (raw[Math.floor(raw.length*0.99)]*1000).toFixed(1) + 'µs';\n    ctx.clearRect(0,0,480,220);\n    var max = Math.max.apply(null, data);\n    var bw = 18, gap = 2, x0 = 40;\n    for (var j = 0; j < bins; j++) {\n      var h = (data[j] / max) * 160;\n      ctx.fillStyle = j < 10 ? '#238636' : '#484f58';\n      ctx.fillRect(x0 + j * (bw+gap), 190 - h, bw, h);\n    }\n    ctx.fillStyle = '#727e8c';\n    ctx.font = '11px system-ui';\n    ctx.fillText('0', 38, 208);\n    ctx.fillText('400µs', 420, 208);\n  }\n  sample();\n  canvas.addEventListener('click', sample);\n})();\n</script>\n</body>\n</html>"}
